VITE_TELEGRAM_BOT_TOKEN=ващ_токен_тут
VITE_TELEGRAM_CHAT_ID=ваш_чат_ід_тут

# Замініть ключ на ваш реальний Google Gemini API Key
GOOGLE_GEMINI_API_KEY=AIzaSy...

# Дані вашого Supabase (можна взяти в Project Settings -> API)
VITE_SUPABASE_URL=https://ваша_supabase_url.supabase.co
VITE_SUPABASE_ANON_KEY=ваш_публічний_anon_key

# Service Role Key для серверної частини (НЕ ПЕРЕДАВАТИ НА ФРОНТЕНД, НЕ ВИКОРИСТОВУВАТИ ПРЕФІКС VITE_)
SUPABASE_SERVICE_ROLE_KEY=ваш_секретний_сервісний_ключ
